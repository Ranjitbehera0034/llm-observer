{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LLM Observer",
  "version": "1.0.0",
  "identifier": "com.llm-observer.desktop",
  "build": {
    "frontendDist": "../../dashboard/dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LLM Observer",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/llm-observer-proxy"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Ranjitbehera0034/llm-observer/releases/latest/download/latest.json"
      ]
    }
  }
}