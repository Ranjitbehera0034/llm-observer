# LLM Observer License Server — Environment Variables

## REQUIRED — must be set in Vercel dashboard

# Shared secret for HMAC-SHA256 license key signing
# Generate: openssl rand -hex 32
LICENSE_SECRET=your-secret-here-generate-with-openssl-rand-hex-32

# Resend API key for sending license keys via email
RESEND_API_KEY=re_your_resend_api_key

# This email appears as the FROM address
FROM_EMAIL=licenses@yourdomain.com

## Lemon Squeezy (Primary payment provider for international)
# From: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_SIGNING_SECRET=your_lemonsqueezy_webhook_signing_secret

## Razorpay (For Indian customers)
# From: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

## Optional — Node environment
NODE_ENV=production
