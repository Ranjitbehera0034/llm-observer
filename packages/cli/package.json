{
  "name": "llm-observer",
  "version": "1.9.0",
  "description": "Privacy-first, local-only LLM cost tracker. Track OpenAI, Anthropic, Gemini costs without sending data to the cloud.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup && cp -r ../database/src/migrations dist/ && cp ../proxy/dist/server.js dist/server.js && mkdir -p dist/dashboard && cp -r ../proxy/dist/dashboard/* dist/dashboard/ && chmod +x dist/index.js",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "llm-observer": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/server.js",
    "dist/dashboard",
    "dist",
    "README.md"
  ],
  "keywords": [
    "llm",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "cost-tracking",
    "observability",
    "proxy",
    "privacy",
    "local-first",
    "developer-tools",
    "ai",
    "typescript",
    "budget",
    "monitoring",
    "groq",
    "mistral",
    "ollama",
    "token-counting",
    "llm-cost"
  ],
  "author": "Ranjit Behera <ranjitbehera0034@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Ranjitbehera0034/llm-observer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ranjitbehera0034/llm-observer.git"
  },
  "bugs": {
    "url": "https://github.com/Ranjitbehera0034/llm-observer/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "node-fetch": "^2.7.0",
    "better-sqlite3": "^11.5.0"
  },
  "devDependencies": {
    "@llm-observer/database": "*",
    "@llm-observer/proxy": "*",
    "@types/node": "^25.3.5",
    "@types/node-fetch": "^2.6.13",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
