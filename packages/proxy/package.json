{
    "name": "@llm-observer/proxy",
    "version": "1.0.0",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsup && mkdir -p dist/dashboard && cp -r ../dashboard/dist/* dist/dashboard/ 2>/dev/null && cp ../database/src/*.sql dist/ 2>/dev/null || true",
        "dev": "ts-node -r tsconfig-paths/register src/server.ts",
        "test": "jest",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@llm-observer/database": "*",
        "chalk": "^4.1.2",
        "cors": "^2.8.5",
        "express": "^4.21.1",
        "http-proxy": "^1.18.1",
        "node-fetch": "^2.7.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.25",
        "@types/http-proxy": "^1.17.15",
        "@types/jest": "^30.0.0",
        "@types/node-fetch": "^2.6.13",
        "@types/supertest": "^7.2.0",
        "jest": "^30.2.0",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "tsup": "^8.5.1",
        "typescript": "^5.5.0"
    }
}
