# LLM Observer Proxy — Environment Variables

## Required
# PORT for the proxy server (default: 4000)
PROXY_PORT=4000

# PORT for the dashboard API server (default: 4001)
DASHBOARD_PORT=4001

## Optional — License Server
# URL of your deployed license server (Vercel)
# Example: https://llm-observer-license.vercel.app
LICENSE_SERVER_URL=https://your-license-server.vercel.app

## Optional — Dashboard URL (for CORS)
DASHBOARD_URL=http://localhost:5173

## Optional — Team Cloud Sync
# URL of your deployed team server
TEAM_SERVER_URL=https://your-team-server.onrender.com
