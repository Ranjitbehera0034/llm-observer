{
  "name": "llm-observer-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Privacy-first LLM cost tracking for developers",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "rm -rf node_modules packages/*/dist packages/*/node_modules"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ranjitbehera0034/llm-observer.git"
  },
  "author": "Ranjit Behera <ranjitbehera0034@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Ranjitbehera0034/llm-observer/issues"
  },
  "homepage": "https://github.com/Ranjitbehera0034/llm-observer#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
